<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".ViewWorkbookFragment">

    <LinearLayout
        android:id="@+id/ll_toolbar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/main2_2"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/gotoBookcase"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/setting_icon" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="문제집 1"
            android:textColor="@color/text3"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <HorizontalScrollView
        android:id="@+id/hsv_numbers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toBottomOf="@id/ll_toolbar">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
            <ImageView android:layout_width="50dp" android:layout_height="50dp" android:layout_margin="4dp" android:src="@drawable/setting_icon" />
        </LinearLayout>
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/ll_question_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="20dp"
        android:background="@drawable/rectangle_temp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_nav"
        app:layout_constraintTop_toBottomOf="@id/hsv_numbers">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Q2. 문제문제문제문제문제문제문제문제"
                    android:textColor="@color/text3"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@color/main1"
                    android:padding="16dp"
                    android:text="카카오 로그인은 카카오계정으로 다양한 서비스에 로그인할 수 있도록 하는 OAuth 2.0 기반의 소셜 로그인 서비스입니다..."
                    android:textColor="@color/text2"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/setting_icon" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="선택한답변답변답변"
                            android:textColor="@color/text3" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/setting_icon" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="선택안한답변답변답변"
                            android:textColor="@color/text2" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingVertical="16dp"
        app:layout_constraintBottom_toTopOf="@id/ll_footer_buttons">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/setting_icon" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="40dp"
            android:text="1 / 10"
            android:textColor="@color/text3"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/setting_icon" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_footer_buttons"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/main2_2"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:src="@drawable/setting_icon" />

        <ImageView
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:src="@drawable/setting_icon" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>