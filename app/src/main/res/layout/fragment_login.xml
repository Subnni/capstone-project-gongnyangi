<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:tools="http://schemas.android.com/tools"
xmlns:app="http://schemas.android.com/apk/res-auto"
android:background="@color/background"
android:orientation="vertical"
android:layout_width="match_parent"
android:layout_height="match_parent">
<ScrollView
    android:id="@+id/rvd1vti7joio"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_weight="1"
    android:background="#F9F8F8"
    android:paddingVertical="145dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:id="@+id/rqjypbvqpgz"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="1dp"
            android:layout_marginBottom="55dp"
            android:layout_marginStart="32dp"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/rpzn1mf86v1f"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/login_header_image"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ra5ecv9fff8bn2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="@drawable/input_box_image"
            android:paddingVertical="15dp"
            android:layout_marginBottom="11dp"
            android:layout_marginHorizontal="31dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/rbq97rfhbk7c"
                android:layout_width="13dp"
                android:layout_height="15dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="11dp"
                android:background="@drawable/login_id_icon"
                android:scaleType="fitXY"
                />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/login_vertical_line_icon"/>

            <TextView
                android:id="@+id/rr41j5k4z7mj"
                android:textColor="#536578"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="전화번호 "
                />
        </LinearLayout>
        <LinearLayout
            android:id="@+id/ra5ecv98bfffn2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:background="@drawable/input_box_image"
            android:paddingVertical="15dp"
            android:layout_marginBottom="11dp"
            android:layout_marginHorizontal="31dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/rbq97rfhbk733c"
                android:layout_width="13dp"
                android:layout_height="15dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="11dp"
                android:background="@drawable/login_pw_icon"
                android:scaleType="fitXY"
                />
            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/login_vertical_line_icon"/>

            <TextView
                android:id="@+id/rr41j522k4z7mj"
                android:textColor="#536578"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"
                android:text="비밀번호 "
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rdy38oqevh2a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="21dp"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rjubfyj7w0rm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/rqvmql3so8r8"
                    android:textColor="#3E4650"
                    android:textSize="15sp"
                    android:layout_marginEnd="10dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="비밀번호 찾기 "
                    />
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/login_vertical_line_icon"/>
                <TextView
                    android:id="@+id/gotoSignUpTextView"
                    android:textColor="#3E4650"
                    android:textSize="15sp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="처음 시작하기"
                    />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/r1fgdwvzvieu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="83dp"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/rlvpr5icxxq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/gotoMainLayout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/login_btn_image"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="로그인"
                        android:textColor="#ffffff"
                        android:textSize="20sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
        <LinearLayout
            android:id="@+id/rletpq4qrrd"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:layout_marginBottom="14dp"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/r4ny0ljbk4hu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/horizontal_line"/>
                <TextView
                    android:id="@+id/rml6atm8nhyp"
                    android:textColor="#3E4650"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp"
                    android:layout_height="wrap_content"
                    android:layout_width="wrap_content"
                    android:text="또는"
                    />
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/horizontal_line"/>

            </LinearLayout>
        </LinearLayout>

        <ImageView
            android:id="@+id/rz9e7kisvyqd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/login_kakao_btn_image" />

    </LinearLayout>
</ScrollView>
</LinearLayout>
