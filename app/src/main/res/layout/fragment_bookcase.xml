<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/main2"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/r7eudn6o6dxy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingTop="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/r24peakppl4z"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="45dp"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/rzuyqcfzo63p"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="17dp"
                    android:layout_marginBottom="30dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/rrnyf22gubkd"
                        android:layout_width="26dp"
                        android:layout_height="20dp"
                        android:layout_marginEnd="16dp"
                        android:scaleType="fitXY"
                        android:background="@drawable/back_btn_white_image" />

                    <TextView
                        android:id="@+id/r7641vuv1mt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="10dp"
                        android:text="내 책장"
                        android:textColor="#3E4650"
                        android:textSize="22sp" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/rrqbc2b3dxaj"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:scaleType="fitXY"
                        android:src="@android:drawable/star_big_on" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/rjweozrk60h8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="28dp"
                    android:layout_marginBottom="5dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/r0at9lh4i72ke"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="55dp"
                        android:text="전체"
                        android:textColor="#458DF1"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/r0wkk5shng4po"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="선반1"
                        android:textColor="#D0CFCF"
                        android:textSize="18sp" />

                    <LinearLayout
                        android:id="@+id/r4h84v7i8hzi"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"></LinearLayout>

                    <TextView
                        android:id="@+id/categorySettingImageButton"
                        android:layout_width="wrap_content"
                        android:layout_height="19dp"
                        android:text="카테고리 설정" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/r31efe7816d2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/rw4cgq1hmxei"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="21dp"
                    android:text="* 누르거나 옆으로 넘겨서 더 많은 문제집을 확인할 수 있어요!"
                    android:textColor="#8096AE"
                    android:textSize="11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/rvp1c3jz6sy"
                android:layout_width="match_parent"
                android:layout_height="229dp"
                android:layout_marginHorizontal="22dp"
                android:layout_marginBottom="23dp"
                android:background="@drawable/bookcase_box_image"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:elevation="4dp"
                android:orientation="vertical"
                android:paddingVertical="16dp"
                android:paddingLeft="20dp"
                android:paddingRight="3dp">

                <LinearLayout
                    android:id="@+id/rwq57emtj9t"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/rc77tr13auhi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="10dp"
                        android:layout_weight="1"
                        android:gravity="end"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/rk5wgzfr8bcq"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="57dp"
                            android:layout_marginBottom="6dp"
                            android:text="개념서1"
                            android:textColor="#3E4650"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/rq82g2vipma"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="만든 날짜 : 2026.01.23."
                            android:textColor="#6C7C8E"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/popupTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="⋮"
                        android:textColor="#3E4650"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <RelativeLayout
                    android:id="@+id/r07xj1vdmm7zn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="9dp"
                    android:clipChildren="false"
                    android:clipToPadding="false">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:orientation="horizontal">


                        <LinearLayout
                            android:id="@+id/tempBook"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#aabbcc"
                            android:orientation="vertical"
                            android:paddingTop="94dp">

                            <LinearLayout
                                android:id="@+id/rqwkso7vyxer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="19dp"
                                android:background="#4F000000"
                                android:orientation="vertical"
                                android:paddingVertical="7dp"
                                android:paddingLeft="47dp"
                                android:paddingRight="5dp">

                                <TextView
                                    android:id="@+id/r9nwjv5mkfmw"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="개념서1"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp" />
                            </LinearLayout>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/tempWorkbook"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="#aabbcc"
                            android:orientation="vertical"
                            android:layout_marginLeft="10dp"
                            android:paddingTop="94dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="19dp"
                                android:background="#4F000000"
                                android:orientation="vertical"
                                android:paddingVertical="7dp"
                                android:paddingLeft="47dp"
                                android:paddingRight="5dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="문제집1"
                                    android:textColor="#FFFFFF"
                                    android:textSize="15sp" />
                            </LinearLayout>
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/addWorkbookImageButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/add_btn_image"/>



                    </LinearLayout>
                </RelativeLayout>

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bookcase_shelf_image"
                    android:scaleType="fitXY" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/r4hk98ohzl9r"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="22dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
