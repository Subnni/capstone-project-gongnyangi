<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/account_nav_graph"
    app:startDestination="@id/LoginFragment">

    <!--로그인-->
    <fragment
        android:id="@+id/LoginFragment"
        android:name="com.example.gongnyangi.LoginFragment">
        <action
            android:id="@+id/gotoSignUp"
            app:destination="@id/SignUpFragment" />
    </fragment>
    <!--회원가입-->
    <fragment
        android:id="@+id/SignUpFragment"
        android:name="com.example.gongnyangi.SignUpFragment">
        <action
            android:id="@+id/gotoWelcome"
            app:destination="@id/WelcomeFragment" />
    </fragment>
    <!--회원가입 완료-->
    <fragment
        android:id="@+id/WelcomeFragment"
        android:name="com.example.gongnyangi.WelcomeFragment">
    </fragment>

</navigation>